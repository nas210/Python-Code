"""Nimm is an ancient game of strategy that is named after the old German word for "take." It is also called Tiouk Tiouk in West Africa and Tsynshidzi in China. Players alternate taking stones until there are zero left. The game of Nimm goes as follows:
The game starts with a pile of 20 stones between the players
The two players alternate turns
On a given turn, a player may take either 1 or 2 stone from the center pile
The two players continue until the center pile has run out of stones.
The last player to take a stone loses."""
player = 1

if player == 1:
    player_name = 'Player 1'
elif player == 2:
    player_name = 'Player 2'   


def main():
    global player
    num_of_stones = 20 # starting num of stones
    invalid_input = 3

    while num_of_stones > 0: # Checks if the stones ran out
        print(f'There are {str(num_of_stones)} stones left.')

        player_name = f'Player {str(player)}'
        user_choice = int(input(f"{player_name} would you like to remove 1 or 2 stones? " ))

        print() #space

        if user_choice == 2 and num_of_stones ==1:
            print("You can only remove one") #in the case that the user removes too many stones (e.g: 1 stone left, remove two, stones remaining = -1)
        else:
            while (user_choice >= invalid_input):
                user_choice = int(input("Please enter 1 or 2: "))
            num_of_stones = num_of_stones - user_choice
        change_player()

    print("Game over") #while loop completed which means there are no more stones left
    if player == 2:
        print('player 1')
    elif player == 1:
        print('player 2')

def change_player(): # changes player each turn
        global player
        if player == 1: 
            player = player + 1
        elif player == 2:
            player = player -1    
if __name__ == '__main__':
    main()
