"""
Write a program that implements the following process.
Have the user input a positive integer, call it n.
If n is even, divide it by two.
If n is odd, multiply it by three and add one.
Continue this process until n is equal to one.
"""
user_choice = 0 # this assigns an empty value to user_choice

def main():
    while user_choice != 1:
        user_input()
        odd_even()

def user_input(): # takes a number from the user
    global user_choice
    user_choice = int(input("Enter a number: "))

def odd_even(): #determains whether to number is odd or even
    global user_choice
    while user_choice != 1: # repeats sequence until user_choice = 1
        odd = int((3 * user_choice) + 1)
        even = int(user_choice / 2)
        remainder = int(user_choice % 2)

        if remainder == 1: # if the remainder is 1, the number is odd
            print(f'{str(user_choice)} is odd, so I make 3n + 1: {str(odd)}')
            user_choice = odd # since we have to save this, we set user_choice = odd
        else:
            print(f'{str(user_choice)} is even, so I take half: {str(even)}')
            user_choice = even # '' ... user_choice = even
        

    
if __name__ == "__main__":
    main()
